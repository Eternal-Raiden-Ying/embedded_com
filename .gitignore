# Codex scratch
.codex

# Python
__pycache__/
.venv/
*.py[cod]
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.eggs/
dist/

# CMake build artifacts
**/build/
**/CMakeFiles/
**/CMakeCache.txt
**/cmake_install.cmake

# Logs - strict patterns
*.out
*.log
vision.out*
logs/
**/logs/
**/logs/*

# Audio outputs
*.wav
*.bag
Voice/tts_out/
Voice/tts_cache/
Voice/logs/
Voice/pids/
Voice/runs/

# Architecture-specific native libraries may be required at runtime on board.
# Do not ignore *.so globally; keep intentional native camera extensions visible.
**/cxx/

# PID files
pids/
**/pids/
**/pids/*.pid

# Run data (runtime generated)
runs/
**/runs/
tmp/

# Large QNN model binaries (consider git LFS for these)
*.amf
*.ctx.bin

# Voice third-party assets stay local on board and are not tracked in Git.
Voice/thirdparty/
VISTA/grasp_module/graspness_unofficial/
VISTA/vision_module/model/*

# Environment
.env
*.env
configs/mobile_gateway.mqtt.yaml

# Test data and extracts for offline edge test
VISTA/Offline_Edge_Test/test_data/
VISTA/Offline_Edge_Test/bag_extract/

# Committed archives (test data, not source)
*.zip

# Snapshots, PIDs, and runs for online edge detect
VISTA/Online_Edge_Detect/snapshots/
VISTA/Online_Edge_Detect/pids/
VISTA/Online_Edge_Detect/runs/

# IDE
.vscode/
.idea/
*.swp
*~
Voice_service/
