# Local runtime environment and large local-only assets
env/
output_dataset/
grasp_module/weights/
grasp_module/log/
grasp_module/test/data/
grasp_module/test/debug_res/

# Local mirrors / cloned third-party repositories
# Strategy for this project:
# - MinkowskiEngineCuda13: maintain in its own remote repo
# - pointnet2: vendor source into third_party/pointnet2
# - anygrasp_sdk source tree: keep ignored here after vendoring the needed pointnet2 source
# - graspness_unofficial: reference only, not part of the runtime repo
# - graspnetAPI / yolo-source: local mirrors only unless you decide to vendor them later
anygrasp_sdk/
graspness_unofficial/
graspnetAPI/
MinkowskiEngineCuda13/
yolo-source/

# Python cache
__pycache__/
.ipynb_checkpoints/
*.pyc
*.pyo
*.pyd

# Dataset and debug artifacts
*.bag
*.ply
*.npy

# Native extension build outputs
grasp_module/backend/models/knn/build/
grasp_module/backend/models/knn/*.egg-info/
third_party/pointnet2/build/
third_party/pointnet2/*.egg-info/
third_party/pointnet2/pointnet2/__pycache__/

# IDE / local workspace
.vscode/
.vs/
