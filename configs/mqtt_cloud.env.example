MQTT_HOST=your-broker-domain.com
MQTT_PORT=443
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
MQTT_CLIENT_ID=sc171_car_01
MQTT_TOPIC_CMD=robot/v1/SC171/mobile/cmd
MQTT_TOPIC_ACK=robot/v1/SC171/mobile/ack
MQTT_TOPIC_STATUS=robot/v1/SC171/mobile/status
MQTT_TOPIC_HEARTBEAT=robot/v1/SC171/heartbeat
MOBILE_GATEWAY_RUNTIME_MODE=production
MOBILE_GATEWAY_LOG_LEVEL=INFO
MOBILE_GATEWAY_HEARTBEAT_LOG_INTERVAL_S=30
MOBILE_GATEWAY_SUPPRESS_HEARTBEAT_SUCCESS_LOG=1
MOBILE_GATEWAY_ENABLE_RAW_MQTT_DEBUG=0
MOBILE_GATEWAY_ENABLE_LEGACY_COMMAND_COMPAT=1
MOBILE_GATEWAY_CMD_DEDUP_CACHE_SIZE=64
